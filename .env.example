# ===========================================
# Trade Surveillance Platform - Configuration
# ===========================================

# Finnhub API
FINNHUB_API_KEY=your_finnhub_api_key_here

# Symbols to track (comma-separated)
WATCH_SYMBOLS=AAPL,TSLA,JPM,MSFT,GOOGL

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_MARKET_DATA_TOPIC=market-data
KAFKA_ORDERS_TOPIC=orders
KAFKA_TRADES_TOPIC=trades
KAFKA_ALERTS_TOPIC=alerts

# PostgreSQL (Alerts DB)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=surveillance
POSTGRES_USER=surveillance_user
POSTGRES_PASSWORD=surveillance_pass_123

# MinIO (S3-compatible data lake)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret_123
MINIO_BUCKET=surveillance-lake

# Surveillance Thresholds
SPOOFING_CANCEL_THRESHOLD=10
SPOOFING_WINDOW_SECONDS=120
WASH_TRADE_TIME_WINDOW_SECONDS=30
WASH_TRADE_PRICE_TOLERANCE_PCT=0.5
FRONTRUN_WINDOW_SECONDS=60
FRONTRUN_MIN_ORDER_SIZE=10000
